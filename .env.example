# Скопируй этот файл в .env (docker-compose подхватит его сам) и заполни реальными
# значениями. .env в .gitignore — секреты никогда не должны попадать в репозиторий.

# --- MySQL ---
DB_ROOT_PASSWORD=change-me-root-password
ONLINE_SHOP_DB_USER=online_shop_app
ONLINE_SHOP_DB_PASSWORD=change-me-online-shop-password
SPORTMASTER_DB_USER=sportmaster
SPORTMASTER_DB_PASSWORD=change-me-sportmaster-password

# --- YandexGPT (для backend/.env тоже нужно, здесь — для передачи в контейнер) ---
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MAP_MODEL=gpt-oss-20b
YANDEX_REDUCE_MODEL=yandexgpt-5-lite
